
        "# ---------------- INSTALL LIBRARIES ----------------\n",
        "\n",
        "!pip install -q streamlit\n",
        "!pip install -q chromadb\n",
        "!pip install -q sentence-transformers\n",
        "!pip install -q pypdf\n",
        "!pip install -q python-docx\n",
        "!pip install -q langchain-text-splitters\n",
        "!pip install -q pyngrok"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "!pip install -q groq"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "VLcEsj68UBm0",
        "outputId": "b46aab98-1a17-4b64-aebb-b7ec7d0791ed"
      },
      "execution_count": null,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "\u001b[?25l   \u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m0.0/143.7 kB\u001b[0m \u001b[31m?\u001b[0m eta \u001b[36m-:--:--\u001b[0m\r\u001b[2K   \u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m143.7/143.7 kB\u001b[0m \u001b[31m8.1 MB/s\u001b[0m eta \u001b[36m0:00:00\u001b[0m\n",
            "\u001b[?25h"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "%%writefile app.py\n",
        "\n",
        "import streamlit as st\n",
        "import time\n",
        "from pypdf import PdfReader\n",
        "from docx import Document\n",
        "from sentence_transformers import SentenceTransformer\n",
        "from langchain_text_splitters import RecursiveCharacterTextSplitter\n",
        "import chromadb\n",
        "from groq import Groq\n",
        "\n",
        "\n",
        "# =========================================================\n",
        "# PAGE CONFIG\n",
        "# =========================================================\n",
        "\n",
        "st.set_page_config(\n",
        "    page_title=\"RAGNova\",\n",
        "    page_icon=\"⚡\",\n",
        "    layout=\"wide\",\n",
        "    initial_sidebar_state=\"expanded\"\n",
        ")\n",
        "\n",
        "\n",
        "# =========================================================\n",
        "# SESSION STATE\n",
        "# =========================================================\n",
        "\n",
        "if \"messages\" not in st.session_state:\n",
        "    st.session_state.messages = []\n",
        "\n",
        "\n",
        "# =========================================================\n",
        "# GROQ CLIENT\n",
        "# =========================================================\n",
        "\n",
        "llm = Groq(\n",
        "    api_key=\"Enter your Api key\"\n",
        ")\n",
        "\n",
        "\n",
        "# =========================================================\n",
        "# EMBEDDING MODEL\n",
        "# =========================================================\n",
        "\n",
        "embedder = SentenceTransformer(\n",
        "    \"all-MiniLM-L6-v2\"\n",
        ")\n",
        "\n",
        "\n",
        "# =========================================================\n",
        "# VECTOR DATABASE\n",
        "# =========================================================\n",
        "\n",
        "db = chromadb.Client()\n",
        "\n",
        "collection = db.get_or_create_collection(\n",
        "    \"docs\"\n",
        ")\n",
        "\n",
        "\n",
        "# =========================================================\n",
        "# FILE READER\n",
        "# =========================================================\n",
        "\n",
        "def read_file(file_path):\n",
        "\n",
        "    if file_path.endswith(\".pdf\"):\n",
        "\n",
        "        return \"\".join(\n",
        "            p.extract_text() or \"\"\n",
        "            for p in PdfReader(file_path).pages\n",
        "        )\n",
        "\n",
        "    elif file_path.endswith(\".docx\"):\n",
        "\n",
        "        return \"\\n\".join(\n",
        "            p.text\n",
        "            for p in Document(file_path).paragraphs\n",
        "        )\n",
        "\n",
        "    elif file_path.endswith(\".txt\"):\n",
        "\n",
        "        return open(\n",
        "            file_path,\n",
        "            \"r\",\n",
        "            encoding=\"utf-8\"\n",
        "        ).read()\n",
        "\n",
        "    return \"\"\n",
        "\n",
        "\n",
        "# =========================================================\n",
        "# INDEX DOCUMENT\n",
        "# =========================================================\n",
        "\n",
        "def index_document(text):\n",
        "\n",
        "    if not text.strip():\n",
        "        return 0\n",
        "\n",
        "    chunks = RecursiveCharacterTextSplitter(\n",
        "        chunk_size=500,\n",
        "        chunk_overlap=100\n",
        "    ).split_text(text)\n",
        "\n",
        "    embeddings = embedder.encode(\n",
        "        chunks\n",
        "    ).tolist()\n",
        "\n",
        "    collection.add(\n",
        "        documents=chunks,\n",
        "        embeddings=embeddings,\n",
        "        ids=[\n",
        "            str(time.time()) + str(i)\n",
        "            for i in range(len(chunks))\n",
        "        ]\n",
        "    )\n",
        "\n",
        "    return len(chunks)\n",
        "\n",
        "\n",
        "# =========================================================\n",
        "# GET CONTEXT\n",
        "# =========================================================\n",
        "\n",
        "def get_context(question):\n",
        "\n",
        "    if collection.count() == 0:\n",
        "        return \"\"\n",
        "\n",
        "    results = collection.query(\n",
        "        query_embeddings=embedder.encode(\n",
        "            [question]\n",
        "        ).tolist(),\n",
        "        n_results=3\n",
        "    )\n",
        "\n",
        "    return \"\\n\".join(\n",
        "        results[\"documents\"][0]\n",
        "    )\n",
        "\n",
        "\n",
        "# =========================================================\n",
        "# ASK LLM\n",
        "# =========================================================\n",
        "\n",
        "def ask_llm(question, context=\"\"):\n",
        "\n",
        "    prompt = f\"\"\"\n",
        "    Context:\n",
        "    {context}\n",
        "\n",
        "    Question:\n",
        "    {question}\n",
        "    \"\"\"\n",
        "\n",
        "    response = llm.chat.completions.create(\n",
        "        model=\"llama-3.1-8b-instant\",\n",
        "        messages=[\n",
        "            {\n",
        "                \"role\": \"system\",\n",
        "                \"content\": \"You are a helpful AI assistant.\"\n",
        "            },\n",
        "            {\n",
        "                \"role\": \"user\",\n",
        "                \"content\": prompt\n",
        "            }\n",
        "        ]\n",
        "    )\n",
        "\n",
        "    return response.choices[0].message.content\n",
        "\n",
        "\n",
        "def ask(question):\n",
        "\n",
        "    context = get_context(question)\n",
        "\n",
        "    return ask_llm(question, context)\n",
        "\n",
        "\n",
        "# =========================================================\n",
        "# DARK PREMIUM CSS\n",
        "# =========================================================\n",
        "\n",
        "st.markdown(\"\"\"\n",
        "<style>\n",
        "\n",
        "header, #MainMenu, footer {\n",
        "    visibility: hidden;\n",
        "}\n",
        "\n",
        "\n",
        "/* MAIN APP */\n",
        ".stApp {\n",
        "\n",
        "    background: #050816;\n",
        "\n",
        "    color: white;\n",
        "}\n",
        "\n",
        "\n",
        "/* SIDEBAR */\n",
        "section[data-testid=\"stSidebar\"] {\n",
        "\n",
        "    background: #0F172A;\n",
        "\n",
        "    border-right: 1px solid #1E293B;\n",
        "\n",
        "    min-width: 300px !important;\n",
        "\n",
        "    max-width: 300px !important;\n",
        "}\n",
        "\n",
        "\n",
        "/* FILE UPLOADER */\n",
        "[data-testid=\"stFileUploader\"] {\n",
        "\n",
        "    background: #111827;\n",
        "\n",
        "    border: 1px dashed #334155;\n",
        "\n",
        "    border-radius: 18px;\n",
        "\n",
        "    padding: 18px;\n",
        "}\n",
        "\n",
        "\n",
        "/* BUTTON */\n",
        ".stButton button {\n",
        "\n",
        "    width: 100%;\n",
        "\n",
        "    background: #16C784;\n",
        "\n",
        "    color: white;\n",
        "\n",
        "    border: none;\n",
        "\n",
        "    border-radius: 12px;\n",
        "\n",
        "    padding: 12px;\n",
        "\n",
        "    font-size: 16px;\n",
        "\n",
        "    font-weight: 700;\n",
        "}\n",
        "\n",
        "\n",
        "/* HERO */\n",
        ".hero {\n",
        "\n",
        "    display: flex;\n",
        "\n",
        "    flex-direction: column;\n",
        "\n",
        "    align-items: center;\n",
        "\n",
        "    justify-content: center;\n",
        "\n",
        "    margin-top: 180px;\n",
        "}\n",
        "\n",
        "\n",
        "/* TITLE */\n",
        ".hero-title {\n",
        "\n",
        "    font-size: 72px;\n",
        "\n",
        "    font-weight: 800;\n",
        "\n",
        "    color: white;\n",
        "\n",
        "    line-height: 1.1;\n",
        "\n",
        "    width: fit-content;\n",
        "}\n",
        "\n",
        "\n",
        "/* GREEN */\n",
        ".green {\n",
        "\n",
        "    color: #16C784;\n",
        "}\n",
        "\n",
        "\n",
        "/* SUBTITLE */\n",
        ".hero-sub {\n",
        "\n",
        "    width: fit-content;\n",
        "\n",
        "    align-self: flex-start;\n",
        "\n",
        "    margin-left: 18px;\n",
        "\n",
        "    margin-top: 6px;\n",
        "\n",
        "    font-size: 26px;\n",
        "\n",
        "    color: #CBD5E1;\n",
        "\n",
        "    font-weight: 500;\n",
        "}\n",
        "\n",
        "/* CHAT INPUT */\n",
        ".stChatInput {\n",
        "\n",
        "    position:fixed;\n",
        "\n",
        "    bottom:20px;\n",
        "\n",
        "    left:340px;\n",
        "\n",
        "    right:40px;\n",
        "}\n",
        "\n",
        "\n",
        ".stChatInput textarea {\n",
        "\n",
        "    background:#111827 !important;\n",
        "\n",
        "    color:white !important;\n",
        "\n",
        "    border:1px solid #1E293B !important;\n",
        "\n",
        "    border-radius:18px !important;\n",
        "\n",
        "    font-size:16px !important;\n",
        "}\n",
        "\n",
        "\n",
        "/* USER CHAT */\n",
        ".chat-user {\n",
        "\n",
        "    display:flex;\n",
        "\n",
        "    justify-content:flex-end;\n",
        "\n",
        "    margin-bottom:14px;\n",
        "}\n",
        "\n",
        "\n",
        ".chat-user .bubble {\n",
        "\n",
        "    background: linear-gradient(\n",
        "        135deg,\n",
        "        #2563EB,\n",
        "        #7C3AED\n",
        "    );\n",
        "\n",
        "    color:white;\n",
        "\n",
        "    padding:12px 16px;\n",
        "\n",
        "    border-radius:18px 6px 18px 18px;\n",
        "\n",
        "    max-width:70%;\n",
        "}\n",
        "\n",
        "\n",
        "/* BOT CHAT */\n",
        ".chat-bot {\n",
        "\n",
        "    display:flex;\n",
        "\n",
        "    justify-content:flex-start;\n",
        "\n",
        "    margin-bottom:14px;\n",
        "}\n",
        "\n",
        "\n",
        ".chat-bot .bubble {\n",
        "\n",
        "    background:#111827;\n",
        "\n",
        "    border:1px solid #1E293B;\n",
        "\n",
        "    color:white;\n",
        "\n",
        "    padding:12px 16px;\n",
        "\n",
        "    border-radius:6px 18px 18px 18px;\n",
        "\n",
        "    max-width:70%;\n",
        "\n",
        "    line-height:1.6;\n",
        "}\n",
        "\n",
        "\n",
        "/* AVATAR */\n",
        ".av {\n",
        "\n",
        "    width:30px;\n",
        "\n",
        "    height:30px;\n",
        "\n",
        "    border-radius:50%;\n",
        "\n",
        "    background:#1E293B;\n",
        "\n",
        "    display:flex;\n",
        "\n",
        "    align-items:center;\n",
        "\n",
        "    justify-content:center;\n",
        "\n",
        "    font-size:12px;\n",
        "\n",
        "    margin:4px 8px 0;\n",
        "\n",
        "    color:white;\n",
        "}\n",
        "\n",
        "\n",
        "/* SCROLLBAR */\n",
        "::-webkit-scrollbar {\n",
        "    width: 6px;\n",
        "}\n",
        "\n",
        "::-webkit-scrollbar-thumb {\n",
        "    background: #334155;\n",
        "    border-radius: 10px;\n",
        "}\n",
        "\n",
        "</style>\n",
        "\"\"\", unsafe_allow_html=True)\n",
        "\n",
        "\n",
        "# =========================================================\n",
        "# SIDEBAR\n",
        "# =========================================================\n",
        "\n",
        "with st.sidebar:\n",
        "\n",
        "    st.markdown(\"\"\"\n",
        "    <h1 style=\"\n",
        "    color:white;\n",
        "    font-size:38px;\n",
        "    font-weight:800;\n",
        "    margin-top:10px;\n",
        "    \">\n",
        "    RAG<span style='color:#16C784;'>Nova</span>\n",
        "    </h1>\n",
        "    \"\"\", unsafe_allow_html=True)\n",
        "\n",
        "    st.markdown(\"<br>\", unsafe_allow_html=True)\n",
        "\n",
        "    file = st.file_uploader(\n",
        "        \"Upload File\",\n",
        "        type=[\"pdf\", \"docx\", \"txt\"]\n",
        "    )\n",
        "\n",
        "    if file:\n",
        "\n",
        "        path = \"tmp_\" + file.name\n",
        "\n",
        "        with open(path, \"wb\") as f:\n",
        "            f.write(file.getbuffer())\n",
        "\n",
        "        text = read_file(path)\n",
        "\n",
        "        n = index_document(text)\n",
        "\n",
        "        st.success(f\"✓ {file.name}\")\n",
        "\n",
        "        st.caption(\n",
        "            f\"{n} chunks · {collection.count()} vectors\"\n",
        "        )\n",
        "\n",
        "    st.markdown(\n",
        "        \"<br><br><br><br><br><br>\",\n",
        "        unsafe_allow_html=True\n",
        "    )\n",
        "\n",
        "    st.markdown(\"\"\"\n",
        "    <div style=\"\n",
        "    color:#22C55E;\n",
        "    font-size:15px;\n",
        "    \">\n",
        "    ● Agent online\n",
        "    </div>\n",
        "    \"\"\", unsafe_allow_html=True)\n",
        "\n",
        "    st.markdown(\"---\")\n",
        "\n",
        "    if st.button(\"🗑 Clear chat\"):\n",
        "\n",
        "        st.session_state.messages = []\n",
        "\n",
        "        st.rerun()\n",
        "\n",
        "\n",
        "# =========================================================\n",
        "# HERO SECTION\n",
        "# =========================================================\n",
        "if not st.session_state.messages:\n",
        "    st.markdown(\"<br>\" * 6, unsafe_allow_html=True)\n",
        "    st.markdown(\"\"\"\n",
        "        <div style=\"text-align:left;\">\n",
        "            <h1 style=\"font-size:48px; font-weight:800; color:white; margin:0 0 4px 0; padding:0;\">\n",
        "                Welcome to RAG<span style=\"color:#16C784;\">Nova</span> ⚡\n",
        "            </h1>\n",
        "            <p style=\"color:#94A3B8; font-size:18px; margin:0; padding:0;\">\n",
        "                Upload documents and chat with your AI assistant\n",
        "            </p>\n",
        "        </div>\n",
        "    \"\"\", unsafe_allow_html=True)\n",
        "\n",
        "# =========================================================\n",
        "# CHAT HISTORY\n",
        "# =========================================================\n",
        "\n",
        "for msg in st.session_state.messages:\n",
        "\n",
        "    if msg[\"role\"] == \"user\":\n",
        "\n",
        "        st.markdown(f\"\"\"\n",
        "        <div class=\"chat-user\">\n",
        "            <div class=\"bubble\">\n",
        "                {msg[\"content\"]}\n",
        "            </div>\n",
        "            <div class=\"av\">🤵</div>\n",
        "        </div>\n",
        "        \"\"\", unsafe_allow_html=True)\n",
        "\n",
        "    else:\n",
        "\n",
        "        st.markdown(f\"\"\"\n",
        "        <div class=\"chat-bot\">\n",
        "            <div class=\"av\">🤖</div>\n",
        "            <div class=\"bubble\">\n",
        "                {msg[\"content\"]}\n",
        "            </div>\n",
        "        </div>\n",
        "        \"\"\", unsafe_allow_html=True)\n",
        "\n",
        "\n",
        "# =========================================================\n",
        "# CHAT INPUT\n",
        "# =========================================================\n",
        "\n",
        "question = st.chat_input(\n",
        "    \"How can I help you today?\"\n",
        ")\n",
        "\n",
        "\n",
        "# =========================================================\n",
        "# RESPONSE\n",
        "# =========================================================\n",
        "\n",
        "if question:\n",
        "\n",
        "    st.session_state.messages.append(\n",
        "        {\n",
        "            \"role\": \"user\",\n",
        "            \"content\": question\n",
        "        }\n",
        "    )\n",
        "\n",
        "    with st.spinner(\"Thinking...\"):\n",
        "\n",
        "        try:\n",
        "\n",
        "            answer = ask(question)\n",
        "\n",
        "        except Exception as e:\n",
        "\n",
        "            answer = f\"Error: {e}\"\n",
        "\n",
        "    st.session_state.messages.append(\n",
        "        {\n",
        "            \"role\": \"assistant\",\n",
        "            \"content\": answer\n",
        "        }\n",
        "    )\n",
        "\n",
        "    st.rerun()"
      ],
      "metadata": {
